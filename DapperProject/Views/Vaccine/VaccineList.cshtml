@model List<DapperProject.Dtos.VaccineDtos.ResultVaccineDto>
@{
    ViewData["Title"] = "Aşı Takibi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int currentPage   = ViewBag.CurrentPage;
    int totalPages    = ViewBag.TotalPages;
    int totalCount    = ViewBag.TotalCount;
    string petName    = ViewBag.PetName     ?? "";
    string vaccineName= ViewBag.VaccineName ?? "";
    string status     = ViewBag.Status      ?? "";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 style="color:#e2e8f0;font-weight:500;margin:0">Aşı Takibi</h5>
        <span style="font-size:12px;color:#94a3b8">Toplam <span style="color:#22d3ee">@totalCount.ToString("N0")</span> aşı kaydı listeleniyor</span>
    </div>
    <a href="/Vaccine/CreateVaccine" class="btn-primary-dark">
        <i class="bi bi-plus"></i> Yeni Aşı Kaydı
    </a>
</div>

<!-- FİLTRELEME -->
<div class="dark-card mb-4">
    <form method="get" action="/Vaccine/VaccineList">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="dark-label">Hayvan Adı</label>
                <input type="text" name="petName" value="@petName" class="dark-input" placeholder="Hayvan adı ara..." />
            </div>
            <div class="col-md-3">
                <label class="dark-label">Aşı Adı</label>
                <input type="text" name="vaccineName" value="@vaccineName" class="dark-input" placeholder="Aşı adı ara..." />
            </div>
            <div class="col-md-3">
                <label class="dark-label">Durum</label>
                <select name="status" class="dark-select">
                    <option value="">Tümü</option>
                    <option value="Gecikmiş"  @@(status == "Gecikmiş"  ? "selected" : "")>Gecikmiş</option>
                    <option value="Yaklaşan"  @@(status == "Yaklaşan"  ? "selected" : "")>Yaklaşan (30 gün)</option>
                    <option value="Normal"    @@(status == "Normal"    ? "selected" : "")>Normal</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn-primary-dark w-100">
                    <i class="bi bi-search"></i> Filtrele
                </button>
                <a href="/Vaccine/VaccineList" class="tb-btn w-100 justify-content-center">
                    <i class="bi bi-x"></i>
                </a>
            </div>
        </div>
    </form>
</div>

<!-- TABLO -->
<div class="dark-card mb-3">
    <table class="dark-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Hayvan / Tür</th>
                <th>Sahip</th>
                <th>Telefon</th>
                <th>Veteriner</th>
                <th>Aşı Adı</th>
                <th>Aşı Tarihi</th>
                <th>Sonraki Tarih</th>
                <th>Seri No</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var vac in Model)
                {
                    // Durum hesapla
                    string badgeClass = "badge-wait";
                    string badgeText  = "Normal";
                    if (DateTime.TryParse(vac.NextDueDate, out DateTime nextDate))
                    {
                        if (nextDate < DateTime.Today)
                        {
                            badgeClass = "badge-canc";
                            badgeText  = "Gecikmiş";
                        }
                        else if (nextDate <= DateTime.Today.AddDays(30))
                        {
                            badgeClass = "badge-prog";
                            badgeText  = "Yaklaşan";
                        }
                        else
                        {
                            badgeClass = "badge-done";
                            badgeText  = "Normal";
                        }
                    }
                    <tr>
                        <td style="color:#94a3b8">@vac.VaccineId</td>
                        <td>
                            <div class="cell-name">@vac.PetName</div>
                            <div class="cell-sub">@vac.SpeciesName</div>
                        </td>
                        <td>@vac.OwnerName</td>
                        <td style="font-size:12px;color:#6b7280">@vac.OwnerPhone</td>
                        <td>@vac.VetName</td>
                        <td>
                            <span style="background:#1e1b4b;color:#818cf8;font-size:11px;padding:2px 8px;border-radius:99px;">
                                @vac.VaccineName
                            </span>
                        </td>
                        <td style="font-size:12px;color:#6b7280">@vac.VaccineDate</td>
                        <td style="font-size:12px;color:#e2e8f0">@vac.NextDueDate</td>
                        <td style="font-size:11px;color:#94a3b8">@vac.BatchNo</td>
                        <td><span class="@badgeClass">@badgeText</span></td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="/Vaccine/UpdateVaccine/@vac.VaccineId" class="btn-edit-dark">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/Vaccine/DeleteVaccine/@vac.VaccineId"
                                   onclick="return confirm('Bu aşı kaydını silmek istediğinize emin misiniz?')"
                                   class="btn-danger-dark">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="11" style="text-align:center;padding:40px;color:#94a3b8">
                        <i class="bi bi-shield-check" style="font-size:32px;display:block;margin-bottom:8px"></i>
                        Aşı kaydı bulunamadı
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- SAYFALAMA -->
<div class="d-flex align-items-center justify-content-between">
    <span style="font-size:12px;color:#94a3b8">
        Sayfa <span style="color:#e2e8f0">@currentPage</span> / <span style="color:#e2e8f0">@totalPages</span>
        &nbsp;·&nbsp; Toplam <span style="color:#22d3ee">@totalCount.ToString("N0")</span> kayıt
    </span>
    <div class="pagination-dark">
        @if (currentPage > 1)
        {
            <a href="/Vaccine/VaccineList?petName=@petName&vaccineName=@vaccineName&status=@status&page=1" class="page-btn">
                <i class="bi bi-chevron-double-left"></i>
            </a>
            <a href="/Vaccine/VaccineList?petName=@petName&vaccineName=@vaccineName&status=@status&page=@(currentPage-1)" class="page-btn">
                <i class="bi bi-chevron-left"></i>
            </a>
        }
        @{
            int startPage = Math.Max(1, currentPage - 2);
            int endPage   = Math.Min(totalPages, currentPage + 2);
        }
        @for (int i = startPage; i <= endPage; i++)
        {
            <a href="/Vaccine/VaccineList?petName=@petName&vaccineName=@vaccineName&status=@status&page=@i"
               class="page-btn @(i == currentPage ? "active" : "")">@i</a>
        }
        @if (currentPage < totalPages)
        {
            <a href="/Vaccine/VaccineList?petName=@petName&vaccineName=@vaccineName&status=@status&page=@(currentPage+1)" class="page-btn">
                <i class="bi bi-chevron-right"></i>
            </a>
            <a href="/Vaccine/VaccineList?petName=@petName&vaccineName=@vaccineName&status=@status&page=@totalPages" class="page-btn">
                <i class="bi bi-chevron-double-right"></i>
            </a>
        }
    </div>
</div>


