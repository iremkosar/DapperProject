@model DapperProject.Dtos.OwnerDtos.GetOwnerByIdDto
@{
    ViewData["Title"] = "Sahip Güncelle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 style="color:#e2e8f0;font-weight:500;margin:0">Sahip Güncelle</h5>
        <span style="font-size:12px;color:#444466">Sahip #@Model.OwnerId bilgilerini güncelleyin</span>
    </div>
    <a href="/Owner/OwnerList" class="tb-btn">
        <i class="bi bi-arrow-left"></i> Geri Dön
    </a>
</div>

<div class="dark-card" style="max-width:700px;">
    <form method="post" action="/Owner/UpdateOwner">
        <input type="hidden" name="OwnerId" value="@Model.OwnerId" />
        <div class="row g-3">
            <div class="col-md-6">
                <label class="dark-label">Ad Soyad</label>
                <input type="text" name="FullName" value="@Model.FullName" class="dark-input" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Cinsiyet</label>
                <select name="Gender" class="dark-select">
                    <option value="E" @@(Model.Gender?.Trim() == "E" ? "selected" : "")>Erkek</option>
                    <option value="K" @@(Model.Gender?.Trim() == "K" ? "selected" : "")>Kadın</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="dark-label">Telefon</label>
                <input type="text" name="Phone" value="@Model.Phone" class="dark-input" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">E-posta</label>
                <input type="email" name="Email" value="@Model.Email" class="dark-input" />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Şehir</label>
                <select name="City" class="dark-select">
                    @foreach (var c in new[]{"İstanbul","Ankara","İzmir","Bursa","Antalya","Adana","Konya","Gaziantep","Mersin","Kayseri"})
                    {
                        <option value="@c" @@(Model.City == c ? "selected" : "")>@c</option>
                    }
                </select>
            </div>
            <div class="col-12 d-flex gap-2 mt-2">
                <button type="submit" class="btn-primary-dark">
                    <i class="bi bi-check-lg"></i> Güncelle
                </button>
                <a href="/Owner/OwnerList" class="tb-btn">
                    <i class="bi bi-x"></i> İptal
                </a>
            </div>
        </div>
    </form>
</div>

