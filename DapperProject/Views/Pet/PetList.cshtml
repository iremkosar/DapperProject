@model List<DapperProject.Dtos.PetDtos.ResultPetDto>
@{
    ViewData["Title"] = "Hayvan Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int currentPage = ViewBag.CurrentPage;
    int totalPages  = ViewBag.TotalPages;
    int totalCount  = ViewBag.TotalCount;
    string name     = ViewBag.Name    ?? "";
    string species  = ViewBag.Species ?? "";
    string gender   = ViewBag.Gender  ?? "";
}
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 style="color:#e2e8f0;font-weight:500;margin:0">Hayvan Listesi</h5>
        <span style="font-size:12px;color:#94a3b8">Toplam <span style="color:#22d3ee">@totalCount.ToString("N0")</span> hayvan listeleniyor</span>
    </div>
    <div class="d-flex gap-2">
        <a href="/Pet/ExportExcel" class="tb-btn">
            <i class="bi bi-download"></i> Excel İndir
        </a>
        <a href="/Pet/CreatePet" class="btn-primary-dark">
            <i class="bi bi-plus"></i> Yeni Hayvan
        </a>
    </div>
</div>

<!-- FİLTRELEME -->
<div class="dark-card mb-4">
    <form method="get" action="/Pet/PetList">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="dark-label">Hayvan Adı</label>
                <input type="text" name="name" value="@name" class="dark-input" placeholder="Hayvan adı ara..." />
            </div>
            <div class="col-md-3">
                <label class="dark-label">Tür</label>
                <select name="species" class="dark-select">
                    <option value="">Tümü</option>
                    @foreach (var s in new[]{"Kedi","Köpek","Kuş","Tavşan","Hamster","Balık","Sürüngen"})
                    {
                        <option value="@s" @@(species == s ? "selected" : "")>@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="dark-label">Cinsiyet</label>
                <select name="gender" class="dark-select">
                    <option value="">Tümü</option>
                    <option value="Erkek" @@(gender == "Erkek" ? "selected" : "")>Erkek</option>
                    <option value="Dişi"  @@(gender == "Dişi"  ? "selected" : "")>Dişi</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn-primary-dark w-100">
                    <i class="bi bi-search"></i> Filtrele
                </button>
                <a href="/Pet/PetList" class="tb-btn w-100 justify-content-center">
                    <i class="bi bi-x"></i>
                </a>
            </div>
        </div>
    </form>
</div>

<!-- TABLO -->
<div class="dark-card mb-3">
    <table class="dark-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Ad</th>
                <th>Tür</th>
                <th>Irk</th>
                <th>Sahip</th>
                <th>Cinsiyet</th>
                <th>Doğum Tarihi</th>
                <th>Kısırlaştırıldı</th>
                <th>Ağırlık</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var pet in Model)
                {
                    <tr>
                        <td style="color:#94a3b8">@pet.PetId</td>
                        <td class="cell-name">@pet.Name</td>
                        <td>
                            <span style="background:#052e16;color:#10b981;font-size:11px;padding:2px 8px;border-radius:99px;">
                                @pet.SpeciesName
                            </span>
                        </td>
                        <td style="font-size:12px;color:#6b7280">@pet.BreedName</td>
                        <td>@pet.OwnerName</td>
                        <td>
                            @if (pet.Gender == "Erkek")
                            {
                                <span style="color:#38bdf8"><i class="bi bi-gender-male"></i> Erkek</span>
                            }
                            else
                            {
                                <span style="color:#f472b6"><i class="bi bi-gender-female"></i> Dişi</span>
                            }
                        </td>
                        <td style="font-size:12px;color:#6b7280">@pet.BirthDate</td>
                        <td>
                            @if (pet.IsNeutered)
                            {
                                <span class="badge-done">Evet</span>
                            }
                            else
                            {
                                <span class="badge-canc">Hayır</span>
                            }
                        </td>
                        <td style="color:#f59e0b;font-weight:500;">@pet.Weight kg</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="/Pet/UpdatePet/@pet.PetId" class="btn-edit-dark">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/Pet/DeletePet/@pet.PetId"
                                   onclick="return confirm('Bu hayvanı silmek istediğinize emin misiniz?')"
                                   class="btn-danger-dark">
                                    <i class="bi bi-trash"></i>
                                </a>
                                <a href="/Pet/PetDetail/@pet.PetId" class="btn-edit-dark">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10" style="text-align:center;padding:40px;color:#94a3b8">
                        <i class="bi bi-heart" style="font-size:32px;display:block;margin-bottom:8px"></i>
                        Hayvan bulunamadı
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- SAYFALAMA -->
<div class="d-flex align-items-center justify-content-between">
    <span style="font-size:12px;color:#94a3b8">
        Sayfa <span style="color:#e2e8f0">@currentPage</span> / <span style="color:#e2e8f0">@totalPages</span>
        &nbsp;·&nbsp; Toplam <span style="color:#22d3ee">@totalCount.ToString("N0")</span> kayıt
    </span>
    <div class="pagination-dark">
        @if (currentPage > 1)
        {
            <a href="/Pet/PetList?name=@name&species=@species&gender=@gender&page=1" class="page-btn">
                <i class="bi bi-chevron-double-left"></i>
            </a>
            <a href="/Pet/PetList?name=@name&species=@species&gender=@gender&page=@(currentPage-1)" class="page-btn">
                <i class="bi bi-chevron-left"></i>
            </a>
        }
        @{
            int startPage = Math.Max(1, currentPage - 2);
            int endPage   = Math.Min(totalPages, currentPage + 2);
        }
        @for (int i = startPage; i <= endPage; i++)
        {
            <a href="/Pet/PetList?name=@name&species=@species&gender=@gender&page=@i"
               class="page-btn @(i == currentPage ? "active" : "")">@i</a>
        }
        @if (currentPage < totalPages)
        {
            <a href="/Pet/PetList?name=@name&species=@species&gender=@gender&page=@(currentPage+1)" class="page-btn">
                <i class="bi bi-chevron-right"></i>
            </a>
            <a href="/Pet/PetList?name=@name&species=@species&gender=@gender&page=@totalPages" class="page-btn">
                <i class="bi bi-chevron-double-right"></i>
            </a>
        }
    </div>
</div>

