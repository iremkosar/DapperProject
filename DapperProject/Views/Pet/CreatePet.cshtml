@model DapperProject.Dtos.PetDtos.CreatePetDto
@{
    ViewData["Title"] = "CreatePet";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 style="color:#e2e8f0;font-weight:500;margin:0">Yeni Hayvan Ekle</h5>
        <span style="font-size:12px;color:#444466">Yeni hayvan kaydı oluşturun</span>
    </div>
    <a href="/Pet/PetList" class="tb-btn">
        <i class="bi bi-arrow-left"></i> Geri Dön
    </a>
</div>

<div class="dark-card" style="max-width:700px;">
    <form method="post" action="/Pet/CreatePet">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="dark-label">Sahip ID</label>
                <input type="number" name="OwnerId" class="dark-input" placeholder="Sahip ID giriniz" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Ad</label>
                <input type="text" name="Name" class="dark-input" placeholder="Hayvan adı giriniz" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Tür ID</label>
                <select name="SpeciesId" class="dark-select">
                    <option value="1">Kedi</option>
                    <option value="2">Köpek</option>
                    <option value="3">Kuş</option>
                    <option value="4">Tavşan</option>
                    <option value="5">Hamster</option>
                    <option value="6">Balık</option>
                    <option value="7">Sürüngen</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="dark-label">Irk ID</label>
                <input type="number" name="BreedId" class="dark-input" placeholder="Irk ID giriniz" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Cinsiyet</label>
                <select name="Gender" class="dark-select">
                    <option value="Erkek">Erkek</option>
                    <option value="Dişi">Dişi</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="dark-label">Doğum Tarihi</label>
                <input type="date" name="BirthDate" class="dark-input" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Ağırlık (kg)</label>
                <input type="number" step="0.1" name="Weight" class="dark-input" placeholder="0.0" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Kısırlaştırıldı mı?</label>
                <select name="IsNeutered" class="dark-select">
                    <option value="false">Hayır</option>
                    <option value="true">Evet</option>
                </select>
            </div>
            <div class="col-12 d-flex gap-2 mt-2">
                <button type="submit" class="btn-primary-dark">
                    <i class="bi bi-check-lg"></i> Kaydet
                </button>
                <a href="/Pet/PetList" class="tb-btn">
                    <i class="bi bi-x"></i> İptal
                </a>
            </div>
        </div>
    </form>
</div>


