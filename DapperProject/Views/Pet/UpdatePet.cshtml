@model DapperProject.Dtos.PetDtos.GetPetByIdDto
@{
    ViewData["Title"] = "Hayvan Güncelle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 style="color:#e2e8f0;font-weight:500;margin:0">Hayvan Güncelle</h5>
        <span style="font-size:12px;color:#444466">Hayvan #@Model.PetId bilgilerini güncelleyin</span>
    </div>
    <a href="/Pet/PetList" class="tb-btn">
        <i class="bi bi-arrow-left"></i> Geri Dön
    </a>
</div>

<div class="dark-card" style="max-width:700px;">
    <form method="post" action="/Pet/UpdatePet">
        <input type="hidden" name="PetId" value="@Model.PetId" />
        <div class="row g-3">
            <div class="col-md-6">
                <label class="dark-label">Sahip ID</label>
                <input type="number" name="OwnerId" value="@Model.OwnerId" class="dark-input" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Ad</label>
                <input type="text" name="Name" value="@Model.Name" class="dark-input" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Tür</label>
                <select name="SpeciesId" class="dark-select">
                    <option value="1" @@(Model.SpeciesId == 1 ? "selected" : "")>Kedi</option>
                    <option value="2" @@(Model.SpeciesId == 2 ? "selected" : "")>Köpek</option>
                    <option value="3" @@(Model.SpeciesId == 3 ? "selected" : "")>Kuş</option>
                    <option value="4" @@(Model.SpeciesId == 4 ? "selected" : "")>Tavşan</option>
                    <option value="5" @@(Model.SpeciesId == 5 ? "selected" : "")>Hamster</option>
                    <option value="6" @@(Model.SpeciesId == 6 ? "selected" : "")>Balık</option>
                    <option value="7" @@(Model.SpeciesId == 7 ? "selected" : "")>Sürüngen</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="dark-label">Irk ID</label>
                <input type="number" name="BreedId" value="@Model.BreedId" class="dark-input" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Cinsiyet</label>
                <select name="Gender" class="dark-select">
                    <option value="Erkek" @@(Model.Gender == "Erkek" ? "selected" : "")>Erkek</option>
                    <option value="Dişi"  @@(Model.Gender == "Dişi"  ? "selected" : "")>Dişi</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="dark-label">Doğum Tarihi</label>
                <input type="text" name="BirthDate" value="@Model.BirthDate" class="dark-input" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Ağırlık (kg)</label>
                <input type="number" step="0.1" name="Weight" value="@Model.Weight" class="dark-input" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Kısırlaştırıldı mı?</label>
                <select name="IsNeutered" class="dark-select">
                    <option value="false" @@(!Model.IsNeutered ? "selected" : "")>Hayır</option>
                    <option value="true"  @@(Model.IsNeutered  ? "selected" : "")>Evet</option>
                </select>
            </div>
            <div class="col-12 d-flex gap-2 mt-2">
                <button type="submit" class="btn-primary-dark">
                    <i class="bi bi-check-lg"></i> Güncelle
                </button>
                <a href="/Pet/PetList" class="tb-btn">
                    <i class="bi bi-x"></i> İptal
                </a>
            </div>
        </div>
    </form>
</div>


