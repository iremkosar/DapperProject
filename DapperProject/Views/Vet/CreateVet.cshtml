@model DapperProject.Dtos.VetDtos.CreateVetDto
@{
    ViewData["Title"] = "Yeni Veteriner";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 style="color:#e2e8f0;font-weight:500;margin:0">Yeni Veteriner Ekle</h5>
        <span style="font-size:12px;color:#444466">Yeni veteriner kaydı oluşturun</span>
    </div>
    <a href="/Vet/VetList" class="tb-btn">
        <i class="bi bi-arrow-left"></i> Geri Dön
    </a>
</div>

<div class="dark-card" style="max-width:700px;">
    <form method="post" action="/Vet/CreateVet">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="dark-label">Ad Soyad</label>
                <input type="text" name="FullName" class="dark-input" placeholder="Dr. Ad Soyad" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">Uzmanlık</label>
                <select name="Specialty" class="dark-select">
                    @foreach (var s in new[] { "Genel Pratisyen", "Cerrahi", "Dermatoloji", "Kardiyoloji", "Onkoloji", "Nöroloji", "Göz Hastalıkları", "Diş Hekimliği", "Egzotik Hayvanlar" })
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="dark-label">Telefon</label>
                <input type="text" name="Phone" class="dark-input" placeholder="05xx xxx xx xx" required />
            </div>
            <div class="col-md-6">
                <label class="dark-label">E-posta</label>
                <input type="email" name="Email" class="dark-input" placeholder="ornek@klinik.com" />
            </div>
            <div class="col-12 d-flex gap-2 mt-2">
                <button type="submit" class="btn-primary-dark">
                    <i class="bi bi-check-lg"></i> Kaydet
                </button>
                <a href="/Vet/VetList" class="tb-btn">
                    <i class="bi bi-x"></i> İptal
                </a>
            </div>
        </div>
    </form>
</div>


