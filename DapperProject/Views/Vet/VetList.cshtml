@model List<DapperProject.Dtos.VetDtos.ResultVetDto>
@{
    ViewData["Title"] = "Veteriner Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h5 style="color:#e2e8f0;font-weight:500;margin:0">Veteriner Listesi</h5>
        <span style="font-size:12px;color:#94a3b8">Toplam <span style="color:#22d3ee">@Model.Count</span> veteriner listeleniyor</span>
    </div>
    <div class="d-flex gap-2">
        <a href="/Pet/ExportExcel" class="tb-btn">
            <i class="bi bi-download"></i> Excel İndir
        </a>
        <a href="/Vet/CreateVet" class="btn-primary-dark">
            <i class="bi bi-plus"></i> Yeni Veteriner
        </a>
    </div>
</div>

<div class="dark-card">
    <table class="dark-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Ad Soyad</th>
                <th>Uzmanlık</th>
                <th>Telefon</th>
                <th>E-posta</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var vet in Model)
                {
                    <tr>
                        <td style="color:#94a3b8">@vet.VetId</td>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#0ea5e9,#6366f1);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff;flex-shrink:0;">
                                    @(string.Join("", vet.FullName.Replace("Dr. ", "").Split(' ').Take(2).Select(w => w[0])))
                                </div>
                                <div class="cell-name">@vet.FullName</div>
                            </div>
                        </td>
                        <td>
                            <span style="background:#1e1b4b;color:#818cf8;font-size:11px;padding:3px 9px;border-radius:99px;">
                                @vet.Specialty
                            </span>
                        </td>
                        <td>@vet.Phone</td>
                        <td style="font-size:12px;color:#6b7280">@vet.Email</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="/Vet/UpdateVet/@vet.VetId" class="btn-edit-dark">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/Vet/DeleteVet/@vet.VetId"
                                   onclick="return confirm('Bu veterineri silmek istediğinize emin misiniz?')"
                                   class="btn-danger-dark">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" style="text-align:center;padding:40px;color:#94a3b8">
                        <i class="bi bi-person-badge" style="font-size:32px;display:block;margin-bottom:8px"></i>
                        Veteriner bulunamadı
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


